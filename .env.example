# ===========================================
# AI Video Generator - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values

# Backend API URLs (Required)
NEXT_PUBLIC_BACKEND_URL=
NEXT_PUBLIC_VIDEO_GEN_API_URL=

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_REDIRECT_URL=

# GitHub OAuth
NEXT_PUBLIC_GITHUB_CLIENT_ID=
NEXT_PUBLIC_GITHUB_REDIRECT_URL=

# Microsoft OAuth
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=
NEXT_PUBLIC_MICROSOFT_REDIRECT_URL=

# Apple OAuth
NEXT_PUBLIC_APPLE_CLIENT_ID=
NEXT_PUBLIC_APPLE_REDIRECT_URL=

# External App URLs
NEXT_PUBLIC_CHATBOT_URL=
NEXT_PUBLIC_MYNOTEBOOKLM_URL=
